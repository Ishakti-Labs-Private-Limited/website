# After you add your custom domain in Vercel → Domains, set this so metadata, sitemap, and Open Graph use the canonical URL.
# Example: https://www.ishaktilabs.com
NEXT_PUBLIC_SITE_URL=

# Optional: form POST endpoint (e.g. Formspree, Basin, Getform). If unset, the contact form opens the visitor’s email client with a prefilled message to hello@ishaktilabs.com.
# NEXT_PUBLIC_FORM_ENDPOINT=

# Optional: Cal.com / Calendly link shown as a secondary line under the form (same discovery intent).
# NEXT_PUBLIC_BOOKING_URL=
